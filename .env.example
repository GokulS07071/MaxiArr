# Centralized configuration variables for the media stack

# Timezone (Asia/Kolkata based on your current time offset)
TZ=Asia/Kolkata

# User and Group IDs for file permissions in containers
PUID=1000
PGID=1000

# Directory paths on the host relative to the workspace directory
CONFIG_ROOT=./config
MEDIA_ROOT=./data

# API Keys for Servarr Applications (Replace these with secure random strings, e.g., 32-char hex values)
SONARR_API_KEY=6b8e39f72a4c4a169b18d2de0c738c82
RADARR_API_KEY=ef4f6a5b7c024d389a42be1df1936b8e
PROWLARR_API_KEY=f2e8d3b5c7a94d80a1c6e5429b6f87ad

# VPN Configuration for Gluetun (Optional, only needed for torrent-vpn profile)
# Use from here: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_SERVICE_PROVIDER=<fill up>
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=<fill up>
WIREGUARD_ADDRESSES=<fill up>
SERVER_COUNTRIES=<fill up>
